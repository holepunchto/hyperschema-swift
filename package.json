{
  "name": "hyperschema-swift",
  "version": "0.0.1",
  "description": "Swift code generation for hyperschema",
  "main": "index.js",
  "exports": {
    "./package": "./package.json",
    ".": "./index.js"
  },
  "files": [
    "lib/*.js",
    "index.js"
  ],
  "imports": {
    "fs": {
      "bare": "bare-fs",
      "default": "fs"
    },
    "path": {
      "bare": "bare-path",
      "default": "path"
    },
    "child_process": {
      "bare": "bare-subprocess",
      "default": "child_process"
    }
  },
  "scripts": {
    "format": "prettier . --write",
    "test": "prettier . --check && brittle test/index.js",
    "test:swift": "prettier . --check && brittle test/swift.js",
    "test:cross-language": "prettier . --check && brittle test/cross-language.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/holepunchto/hyperschema-swift.git"
  },
  "author": "Holepunch",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/holepunchto/hyperschema-swift/issues"
  },
  "homepage": "https://github.com/holepunchto/hyperschema-swift",
  "dependencies": {
    "bare-fs": "^4.0.1",
    "hyperschema": "^1.20.1"
  },
  "devDependencies": {
    "bare-path": "^3.0.0",
    "bare-subprocess": "^5.2.2",
    "brittle": "^3.7.0",
    "compact-encoding": "^2.19.0",
    "prettier": "^3.6.2",
    "prettier-config-holepunch": "^2.0.0",
    "test-tmp": "^1.3.0",
    "which-runtime": "^1.3.2"
  }
}
